    "force_60hz_v1": {
        "name": "Force 60Hz",
        "notes": "7th series engine (6th, 7th, 7th 1.5, 7th 2.0, CV). Uses call [ebp+0x54]. Replaces mov ebx,[edi+0x18] with push 0x3c; pop ebx (3-byte trick to set ebx=60).",
        "games": ["ez2dj_6th", "ez2dj_7th", "ez2dj_7th_15", "ez2dj_7th_20", "ez2dj_cv"],
        "description": "Forces DirectDraw SetDisplayMode to request 60Hz.",
        "type": "toggle",
        "apply": "early",
        "scan": "8b 56 28 53 8b 5f 18 8b 7f 54 8b 2a 53 57 51 50 52 ff 55 54",
        "writes": [
          { "offset": "0x4", "bytes": "6a 3c 5b" }
        ]
      },
      "force_60hz_v2": {
        "name": "Force 60Hz",
        "notes": "BE engine (3rd, 4th, 5th, BE, BE-A, EC). Uses large negative EBP stack offsets. Replaces mov ecx,[eax+0x18]; push ecx(refreshRate) with push 0x3c(60); nop; nop.",
        "games": ["ez2dj_3rd", "ez2dj_4th", "ez2dj_5th", "ez2dj_be", "ez2dj_be_a", "ez2ac_ec"],
        "description": "Forces DirectDraw SetDisplayMode to request 60Hz.",
        "type": "toggle",
        "apply": "early",
        "scan": "52 8b 45 08 8b 48 ?? 51 8b 55 08 8b 42 ?? 50 8b 8d 58 ff ff ff 8b 51 ?? 52",
        "writes": [
          { "offset": "0x4", "bytes": "6a 3c 90 90" }
        ]
      },
      "force_60hz_v3": {
        "name": "Force 60Hz",
        "notes": "EZ2AC engine (EV, NT, TT, FN, FN_EX). Replaces mov edx,[edi+0x18]; push ebx(flags=0); push edx(refreshRate) with push ebx(0); push 0x3c(60); nop; nop.",
        "games": ["ez2ac_ev", "ez2ac_nt", "ez2ac_tt", "ez2ac_fn", "ez2ac_fn_ex"],
        "description": "Forces DirectDraw SetDisplayMode to request 60Hz. ",
        "type": "toggle",
        "apply": "early",
        "scan": "8b 57 ?? 53 52 c7 47 ?? 20 00 00 00 8b 56 ?? 8b 46 ?? 8b 08 6a 20 52 8b 56 ?? 52 50 ff 51 54",
        "writes": [
          { "offset": "0x0", "bytes": "53 6a 3c 90 90" }
        ]
    }
